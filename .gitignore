# Dependencies
node_modules/
.venv/
# Root node_modules symlink -> frontend/node_modules (so plugin TSX
# outside the Vite project can resolve bare imports like "react"). The
# trailing-slash ``node_modules/`` rule above matches real dirs but not
# this root symlink (git treats the symlink as a file), so anchor it.
/node_modules

# Build output
frontend/dist/

